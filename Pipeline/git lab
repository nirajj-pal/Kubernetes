.gitlab-ci.yml

stages:
  - test
  - build
  - deploy

variables:
  DOCKERHUB_IMAGE: "nirajpal/demorepo"
  GITLAB_REPO_URL: "http://172.16.106.49/root/python-pipeline.git"

test:
  stage: test
  image: python:3.9
  before_script:
    - python -m pip install --no-cache-dir -r requirements.txt
    - python -m pip install --no-cache-dir flake8 pytest
  script:
    - echo "Running tests for $CI_PROJECT_DIR"
    - export PYTHONPATH="$PYTHONPATH:$CI_PROJECT_DIR"
    - flake8 app.py
    - pytest test/test_app.py
  tags:
    - docker

build:
  stage: build
  image: docker:24.0.5-cli
  services:
    - name: docker:24.0.5-dind
      command: ["--host=tcp://0.0.0.0:2375", "--tls=false"]
  variables:
    DOCKER_HOST: tcp://docker:2375
    DOCKER_TLS_CERTDIR: ""
    DOCKER_DRIVER: overlay2
  before_script:
    - docker info
    - echo "$DOCKERHUB_TOKEN" | docker login -u "$DOCKERHUB_USERNAME" --password-stdin
  script:
    - docker build -t "$DOCKERHUB_IMAGE:$CI_COMMIT_SHA" .
    - docker push "$DOCKERHUB_IMAGE:$CI_COMMIT_SHA"
  tags:
    - docker

deploy_dev:
  stage: deploy
  image: alpine:3.18.2
  before_script:
    - apk add --no-cache git yq
    - git config --global user.email "gitlab-runner@virtualelephant.com"
    - git config --global user.name "GitLab Runner"
    - git remote set-url origin "http://$GITLAB_USER:$GITLAB_TOKEN@172.16.106.49/root/python-pipeline.git"
    - git fetch origin main
    - git checkout -B main origin/main
  script:
    - echo "Deploying to development environment"
    - yq e -i 'select(.kind == "Deployment").spec.template.spec.containers[0].image = "'$DOCKERHUB_IMAGE:$CI_COMMIT_SHA'"' k8s/dev/python-pipeline-deployment.yaml
    - git add k8s/dev/python-pipeline-deployment.yaml
    - git commit -m "Update Dev deployment image to $CI_COMMIT_SHA [skip ci]" || echo "No changes to commit"
    - git push origin HEAD:main
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'
  tags:
    - docker

deploy_stage:
  stage: deploy
  image: docker:24.0.5-cli
  services:
    - name: docker:24.0.5-dind
      command: ["--host=tcp://0.0.0.0:2375", "--tls=false"]
  variables:
    DOCKER_HOST: tcp://docker:2375
    DOCKER_TLS_CERTDIR: ""
    DOCKER_DRIVER: overlay2
  before_script:
    - apk add --no-cache git yq
    - docker info
    - echo "$DOCKERHUB_TOKEN" | docker login -u "$DOCKERHUB_USERNAME" --password-stdin
    - git config --global user.email "gitlab-runner@virtualelephant.com"
    - git config --global user.name "GitLab Runner"
    - git remote set-url origin "http://$GITLAB_USER:$GITLAB_TOKEN@172.16.106.49/root/python-pipeline.git"
    - git fetch origin main
    - git checkout -B main origin/main
  script:
    - echo "Promoting to stage environment"
    - docker pull "$DOCKERHUB_IMAGE:$CI_COMMIT_SHA"
    - docker tag "$DOCKERHUB_IMAGE:$CI_COMMIT_SHA" "$DOCKERHUB_IMAGE:stage-$CI_COMMIT_SHA"
    - docker push "$DOCKERHUB_IMAGE:stage-$CI_COMMIT_SHA"
    - yq e -i 'select(.kind == "Deployment").spec.template.spec.containers[0].image = "'$DOCKERHUB_IMAGE:stage-$CI_COMMIT_SHA'"' k8s/stage/python-pipeline-deployment.yaml
    - git add k8s/stage/python-pipeline-deployment.yaml
    - git commit -m "Promote SHA $CI_COMMIT_SHA to stage [skip ci]" || echo "No changes to commit"
    - git push origin HEAD:main
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'
      when: manual
  tags:
    - docker
